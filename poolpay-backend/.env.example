# Database
DATABASE_URL=mysql+pymysql://usuario:password@localhost:3306/poolpay?charset=utf8mb4
MYSQL_USER=root
MYSQL_PASSWORD=tu_password
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=poolpay

# API
API_V1_STR=/api/v1
PROJECT_NAME=PoolPay API
VERSION=1.0.0
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000

# Security (genera una clave segura con: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=cambia-esta-clave-secreta-por-una-generada
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Logging
LOG_LEVEL=INFO

