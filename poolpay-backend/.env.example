# Database Configuration
DATABASE_URL=mysql+pymysql://root:tu_password@127.0.0.1:3306/poolpay?charset=utf8mb4
MYSQL_USER=root
MYSQL_PASSWORD=tu_password
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=poolpay

# API Configuration
API_V1_STR=/api/v1
PROJECT_NAME="PoolPay API"
VERSION=1.0.0
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000

# MercadoPago (OBTÉN TU TOKEN EN: https://www.mercadopago.com.ar/developers)
# Para pruebas usa el TEST token, para producción usa el PRODUCTION token
MERCADOPAGO_ACCESS_TOKEN=

# URLs para webhooks y redirecciones
# En producción cambia por tu dominio real
API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# API Key (machine-to-machine, ej. webhooks). Vacío = deshabilitado en dev.
API_KEY=

# JWT — genera SECRET_KEY con: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=cambia-esta-clave-secreta-por-una-generada
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Credenciales del panel web
# ADMIN_PASSWORD puede ser texto plano (dev) o hash bcrypt (prod)
# Para generar hash: python -c "from passlib.context import CryptContext; print(CryptContext(['bcrypt']).hash('tu-password'))"
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# CORS — en producción poner solo tu dominio real, ej:
# BACKEND_CORS_ORIGINS=https://poolpay.tudominio.com,https://api.tudominio.com
# Si se deja vacío, acepta cualquier origen (solo para desarrollo)
BACKEND_CORS_ORIGINS=

# Logging
LOG_LEVEL=INFO

