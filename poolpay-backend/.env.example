# Database Configuration
DATABASE_URL=mysql+pymysql://root:tu_password@127.0.0.1:3306/poolpay?charset=utf8mb4
MYSQL_USER=root
MYSQL_PASSWORD=tu_password
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=poolpay

# API Configuration
API_V1_STR=/api/v1
PROJECT_NAME="PoolPay API"
VERSION=1.0.0
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000

# MercadoPago (OBTÉN TU TOKEN EN: https://www.mercadopago.com.ar/developers)
# Para pruebas usa el TEST token, para producción usa el PRODUCTION token
MERCADOPAGO_ACCESS_TOKEN=

# Webhook signing secret de MP (panel de MP > Notificaciones > Webhooks > Generar clave)
# Solo se valida si MP_VERIFY_SIGNATURE=true. En localhost dejá false.
MERCADOPAGO_WEBHOOK_SECRET=
MP_VERIFY_SIGNATURE=false

# URLs para webhooks y redirecciones
# En producción cambia por tu dominio real
API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ── Scheduler de facturación mensual ─────────────────────────────────────────
# Día del mes que se generan las facturas (default 1) y hora local (24h, default 3)
BILLING_RUN_DAY=1
BILLING_RUN_HOUR=3
# Día de vencimiento de las facturas generadas
BILLING_DUE_DAY=10

# ── Recordatorios de cobranza ────────────────────────────────────────────────
# Hora local diaria a la que corre el scheduler de recordatorios
REMINDERS_RUN_HOUR=9
# Si es true, los recordatorios incluyen un link MP listo para pagar
REMINDERS_INCLUDE_MP_LINK=true

# SMTP para enviar emails de recordatorio. Si está vacío, los recordatorios
# solo se loguean a consola (modo dev).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true

# API Key (machine-to-machine, ej. webhooks). Vacío = deshabilitado en dev.
API_KEY=

# JWT — genera SECRET_KEY con: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=cambia-esta-clave-secreta-por-una-generada
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Credenciales del panel web
# ADMIN_PASSWORD puede ser texto plano (dev) o hash bcrypt (prod)
# Para generar hash: python -c "from passlib.context import CryptContext; print(CryptContext(['bcrypt']).hash('tu-password'))"
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# CORS — en producción poner solo tu dominio real, ej:
# BACKEND_CORS_ORIGINS=https://poolpay.tudominio.com,https://api.tudominio.com
# Si se deja vacío, acepta cualquier origen (solo para desarrollo)
BACKEND_CORS_ORIGINS=

# Logging
LOG_LEVEL=INFO

# ── WhatsApp sender (app de pileteros) ──────────────────────────────────────
# Driver a usar: wame (default) | ultramsg | meta_api | none
# - wame      : genera URL wa.me clickeable para el admin, no envía automático
# - ultramsg  : envía automáticamente via UltraMsg API
# - meta_api  : envía via WhatsApp Business API oficial (pendiente de implementar)
# - none      : modo silencio (tests / dev sin WA)
WHATSAPP_PROVIDER=wame

# Solo si WHATSAPP_PROVIDER=ultramsg:
ULTRAMSG_TOKEN=
ULTRAMSG_INSTANCE=

# Solo si WHATSAPP_PROVIDER=meta_api (pendiente de implementar):
# META_PHONE_NUMBER_ID=
# META_ACCESS_TOKEN=
# META_TEMPLATE_NAME=

